# ============================================================================
# MrTok Framework — variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha os valores reais.
# NUNCA commitar .env.local. Consulte CLAUDE.md §4 (Segurança).
# ============================================================================

# --- Cérebro: Claude Opus 4.6 (API direta Anthropic) -----------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Músculos: OpenRouter (GPT-5.4 / Qwen 3.6 / Minimax 2.7 / Gemini 3) ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase (Dashboard / Task Queue) ------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Telegram (notificações assíncronas OpenClaw) -------------------------
TELEGRAM_BOT_TOKEN=1234567890:AAAxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890

# --- VPS Hostinger (Tailscale) --------------------------------------------
VPS_TAILSCALE_IP=100.72.40.35
# Agente 8 (Analytics) — Gemma 4 local na VPS
GEMMA_LOCAL_URL=http://100.72.40.35:11434

# --- Upload-Post (distribuição multi-plataforma — Tarefa 3) ---------------
UPLOAD_POST_API_KEY=up_xxxxxxxxxxxxxxxxxxxxxxxx
UPLOAD_POST_BASE_URL=https://api.upload-post.com
UPLOAD_POST_PROFILE=mrtok-br-01

# --- Agente CEO (Tarefa 5) — orquestrador de dispatch via cron ------------
# Secret enviado no header `x-ceo-secret` por /api/ceo/tick. Mínimo 16 chars.
CEO_TICK_SECRET=trocar-por-secret-aleatorio-de-32-chars

# --- Segurança / Restrição de rede ----------------------------------------
# Lista de IPs/CIDRs Tailscale autorizados a acessar /api/*
ALLOWED_IPS=100.72.40.35,100.64.0.0/10
# Flag global: quando true, middleware bloqueia qualquer rota não-whitelisted
READ_ONLY_MODE=true
