# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — commitar APENAS o exemplo
.env*
!.env.example

# Worker a7 — chaves privadas de Service Account (NUNCA commitar)
/secrets/

# MrTok — saídas e assets brutos (manter apenas .gitkeep/README)
/output/*
!/output/.gitkeep
!/output/README.md
/raw/*
!/raw/.gitkeep
!/raw/README.md

# MrTok — workspace do renderer (assets baixados do FAL + manifest em tempo de execução)
/workspace/video-renderer/assets/
/workspace/video-renderer/manifest.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase CLI cache local
/supabase/.temp/

# Claude Code — settings locais (podem conter tokens/permissões sensíveis)
.claude/settings.local.json
.claude/scheduled_tasks.lock
